# Copy to .env for local development (never commit the real .env).
# On Render these are set in the dashboard / via render.yaml instead.

# PostgreSQL connection string.
# Render gives you this on the database page (use the "External" URL for local dev).
DATABASE_URL=postgres://user:password@localhost:5432/virtualedge

# Set to "off" only for a local Postgres without SSL. On Render leave it "on".
DATABASE_SSL=off

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Admin dashboard passcode (server-side now — real-ish gate, not just client JS).
ADMIN_PASSCODE=055290

# Google AI Studio (Gemini) key for screenshot scanning. Server-side only — never
# sent to the browser. Leave blank to disable the scanner. Get one at aistudio.google.com.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email (Resend) for the "SportyBet account connected" confirmation. Leave blank to
# skip emails (the flow still works). Get a key + verified sender at resend.com.
RESEND_API_KEY=
MAIL_FROM=VirtualEdge <noreply@yourdomain.com>

# Port (Render sets this automatically; 3000 for local).
PORT=3000
